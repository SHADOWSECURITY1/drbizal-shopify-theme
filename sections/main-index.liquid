{% comment %}
  DrBizal main site section.
  After creating Shopify products, update the product handles below to match.
{% endcomment %}

{% assign special_edition = all_products['the-optimal-life-special-edition-ebook'] %}
{% assign workbook        = all_products['the-optimal-life-workbook-ebook'] %}
{% assign audio_program   = all_products['the-optimal-life-audio-program'] %}
{% assign bundle          = all_products['the-complete-optimal-life-series'] %}
{% assign discovery       = all_products['discovery-session'] %}

<script>
  // Image assets from Shopify CDN
  window.drBizalAssets = {
    audioCover:          '{{ "audio-cover.png"          | asset_url }}',
    bundleCover:         '{{ "bundle-cover.png"         | asset_url }}',
    workbookCover:       '{{ "workbook-cover.png"       | asset_url }}',
    speakingPhoto:       '{{ "speaking-photo.png"       | asset_url }}',
    specialEditionCover: '{{ "special-edition-cover.png" | asset_url }}',
    ittyBittyCover:      '{{ "itty-bitty-cover.png"    | asset_url }}',
    optimalLifeCover:    '{{ "optimal-life-cover.png"  | asset_url }}',
    drBizalPhoto:        '{{ "dr-bizal-photo.jpeg"     | asset_url }}'
  };

  // Shopify product variant IDs (populated from Liquid once products exist)
  window.shopifyProducts = {
    3: { variantId: {{ special_edition.variants.first.id | default: 0 }}, title: '{{ special_edition.title | escape }}' },
    6: { variantId: {{ workbook.variants.first.id        | default: 0 }}, title: '{{ workbook.title | escape }}' },
    7: { variantId: {{ audio_program.variants.first.id   | default: 0 }}, title: '{{ audio_program.title | escape }}' },
    8: { variantId: {{ bundle.variants.first.id          | default: 0 }}, title: '{{ bundle.title | escape }}' }
  };

  // Discovery session Shopify product URL
  window.discoverySessionUrl = '{{ discovery.url | default: "/contact" }}';
</script>

<script src="{{ 'app.js' | asset_url }}" defer></script>
